# API 토큰 — 이 파일을 tokens.env 로 복사한 뒤 값을 채우세요.
#
#   cp tokens.env.example tokens.env
#
# tokens.env 는 .gitignore 에 등록되어 있어 커밋되지 않습니다.
# docker compose up 시 컨테이너 entrypoint 가 자동으로 읽어 로그인합니다.

# GitHub personal access token (private repo clone/pull)
# 이미지에 gh CLI 포함 (apt install gh)
GIT_TOKEN=

# Hugging Face access token (gated dataset: SeunghoEum/mri-tongue-dataset)
# https://huggingface.co/settings/tokens
# 이미지에 hf CLI 포함 (pip install huggingface_hub)
HUGGINGFACE_TOKEN=
