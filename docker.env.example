# docker compose 환경변수 — 이 파일을 .env 로 복사 후 경로 수정
#
#   cp docker.env.example .env

# 소스 코드 마운트 (기본: compose 실행 위치 = mri_transfer 클론 루트 → /workspace)
# PROJECT_DIR=.

# 데이터셋 (기본: ./datasets → /workspace/datasets)
#   ./datasets/dataset_download.sh 로 받으면 이 경로 그대로 사용
#
# 외부 데이터 루트를 쓸 때만 DATA_DIR 변경:
# DATA_DIR=E:/Datasets/XAI/data
# DATA_DIR=/mnt/e/Datasets/XAI/data

# 경로 오버라이드 (컨테이너 내부, /workspace 기준)
# TONGUE_OBJ=/workspace/datasets/tongue_model/tongue_rest_m.obj
# MRI_MASK_DIR=/workspace/datasets/GT_Segmentations/Subject3
# MRI_REST_MASK=/workspace/datasets/GT_Segmentations/Subject3/mask_1.mat
# MRI_TARGET_MASK=/workspace/datasets/GT_Segmentations/Subject3/mask_51.mat

# Hydra CLI (pipeline one-shot: docker compose --profile run run --rm pipeline)
# PIPELINE_ARGS=stage=fem
# PIPELINE_ARGS=stage=retarget artisynth.nramp=40

# JVM
# JVM_XMX=4g
