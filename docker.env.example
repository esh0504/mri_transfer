# docker compose 환경변수 — 이 파일을 .env 로 복사 후 경로 수정
#
#   cp docker.env.example .env

# 소스 코드 마운트 (기본: compose 실행 위치 = mri_transfer 클론 루트)
# PROJECT_DIR=.

# MRI + 혀 메시 루트. 아래 구조를 /data 로 마운트:
#   /data/tongue_model/tongue_rest_m.obj
#   /data/datasets/GT_Segmentations/Subject3/mask_*.mat
#
# Windows 예:
# DATA_DIR=E:/Datasets/XAI/data
# WSL 예:
# DATA_DIR=/mnt/e/Datasets/XAI/data

# 경로 오버라이드 (컨테이너 내부 절대경로)
# TONGUE_OBJ=/data/tongue_model/tongue_rest_m.obj
# MRI_MASK_DIR=/data/datasets/GT_Segmentations/Subject3
# MRI_REST_MASK=/data/datasets/GT_Segmentations/Subject3/mask_1.mat
# MRI_TARGET_MASK=/data/datasets/GT_Segmentations/Subject3/mask_51.mat

# Hydra CLI 오버라이드 (pipeline 서비스)
# PIPELINE_ARGS=stage=fem
# PIPELINE_ARGS=stage=retarget artisynth.nramp=40

# JVM
# JVM_XMX=4g
